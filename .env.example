# Supervisor Node (Groq - Llama 3.3 70B)
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
SUPERVISOR_MODEL=llama-3.3-70b-versatile

# Solver Node (Google AI Studio - Gemini 2.0/1.5)
# Get your key at: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here
SOLVER_MODEL=models/gemini-2.5-pro

# --- System Configuration ---
# Tesseract Path (for Windows local testing)
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Database URL (SQLite is used by default: sqlite:///./memory.db)
DATABASE_URL=sqlite:///./app/memory/memory.db

# Vector DB Path
VECTOR_DB_PATH=./app/rag/faiss_index
